{
  "plugin_id": "ai-copywriter",
  "plugin_name": "AI 文案创作工坊",
  "version": "1.3.1",
  "author": "LemoClaw",
  "description": "基于大模型生成小红书/公众号/营销文案，支持风格定制",
  "config": {
    "default_platform": "xiaohongshu",
    "default_tone": "friendly",
    "max_length": 500,
    "api_model": "gpt-4",
    "api_base_url": "https://api.openai.com/v1/chat/completions"
  },
  "env_vars": {
    "OPENAI_API_KEY": "your-api-key-here",
    "COPYWRITER_MODEL": "gpt-4"
  },
  "install_notes": "需要配置 OpenAI API Key，可在环境变量中设置 OPENAI_API_KEY"
}
